<Window x:Class="EasterEpp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EasterEpp"
        Height="600"
        Width="800"
        Background="LightGreen"
        ResizeMode="NoResize"
        Icon="./images/ee.png">

  <Grid>
    <StackPanel>
      <ContentControl x:Name="MainContent"/>
      <TextBlock x:Name="GlobalScore"
                       FontSize="16"
                       Margin="10"/>
    </StackPanel>
  </Grid>
</Window>